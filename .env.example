# Firebase Configuration
# Copy this file to .env and fill in your values from the Firebase console:
# Project Settings -> General -> Your apps -> SDK setup and configuration

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Admin-managed cloud sync OAuth client IDs (required for one-click connect)
# End users only click Connect in Settings; they never configure OAuth manually.
# Configure provider apps with redirect URI: https://<your-domain>/auth/callback
VITE_SYNC_GOOGLE_CLIENT_ID=
VITE_SYNC_ONEDRIVE_CLIENT_ID=
VITE_SYNC_DROPBOX_CLIENT_ID=

# Hosting/runtime configuration
# Set this for GitHub Pages repos, e.g. /qp-notes/
VITE_BASE_PATH=/

# Optional base URL for passkey HTTP functions when same-origin /api/passkey/* is not wired
# (e.g. static hosting, or Hosting deployed without Functions). Leave empty to use /api on this origin.
# Firebase: after `firebase deploy --only functions`, use your region URL, e.g.
#   https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net
# The client maps /api/passkey/... to function names (authOptions, authVerify, ...).
VITE_PASSKEY_API_BASE=
